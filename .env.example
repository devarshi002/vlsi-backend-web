# ── MongoDB ────────────────────────────────────────────────
# Get from: MongoDB Atlas → Connect → Drivers → copy URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nanocore?retryWrites=true&w=majority
MONGODB_DB=nanocore

# ── Gmail SMTP ─────────────────────────────────────────────
# SENDER: The Gmail that SENDS the alert
# Step 1: Use a Gmail account (e.g. nanocore.alerts@gmail.com)
# Step 2: Go to Google Account → Security → 2-Step Verification → ON
# Step 3: Go to App Passwords → create one → copy the 16-char password
SMTP_EMAIL=your-sender@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char Gmail App Password (NOT your real password)

# RECEIVER: Email that RECEIVES lead alert notifications
ALERT_EMAIL=your-team@gmail.com     # e.g. admissions@nanocore.in

# ── Google Sheets ───────────────────────────────────────────
# Step 1: Go to console.cloud.google.com → New Project
# Step 2: Enable "Google Sheets API" and "Google Drive API"
# Step 3: Create Service Account → Download JSON key → save as credentials.json
# Step 4: Create a Google Sheet → Share it with the service account email (Editor)
# Step 5: Copy the Sheet ID from the URL:
#         https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_CREDENTIALS_FILE=credentials.json  # path to your downloaded service account JSON

# ── App ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
